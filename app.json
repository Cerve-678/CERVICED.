{
  "expo": {
    "name": "CERVICED",
    "slug": "cerviced",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "cerviced",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cerviced.app",
      "buildNumber": "1",
      "userInterfaceStyle": "light",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app uses your location to show nearby beauty service providers.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIUserInterfaceStyle": "Light"
      }
    },
    "android": {
      "package": "com.cerviced.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "userInterfaceStyle": "light",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "PLACEHOLDER_FOR_ANDROID_GOOGLE_MAPS_KEY"
        }
      }
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "expo-video",
      "expo-font",
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#FF9500",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "624d44eb-1d17-4c9a-b782-3675ee5e7863"
      }
    },
    "owner": "umbrellacollective"
  }
}
